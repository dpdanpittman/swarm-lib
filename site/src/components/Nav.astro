---
const links = [
  { href: "/docs", label: "Docs" },
  { href: "/patterns", label: "Patterns" },
  { href: "/examples", label: "Examples" },
];
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---
<nav class="sticky top-0 z-30 border-b border-border bg-bg/90 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-6 py-3 flex items-center justify-between gap-6">
    <a href="/" class="flex items-center gap-2 group no-underline">
      <span class="inline-block w-2 h-2 rounded-full bg-accent shadow-[0_0_10px_rgba(111,211,255,0.6)] group-hover:bg-accent-green transition-colors"></span>
      <span class="font-mono font-semibold tracking-tight text-text">swarm-lib</span>
      <span class="hidden sm:inline text-muted text-sm">— filesystem as orchestrator</span>
    </a>
    <ul class="flex items-center gap-1 text-sm m-0 p-0 list-none">
      {links.map((l) => {
        const active = isActive(l.href);
        return (
          <li>
            <a
              href={l.href}
              class={`px-3 py-1.5 rounded-md transition-colors no-underline ${
                active
                  ? "text-accent bg-accent/10"
                  : "text-muted hover:text-text hover:bg-panel"
              }`}
            >{l.label}</a>
          </li>
        );
      })}
      <li class="ml-2">
        <a
          href="https://github.com/dpdanpittman/swarm-lib"
          target="_blank"
          rel="noopener"
          class="px-3 py-1.5 rounded-md text-sm text-muted no-underline border border-border hover:text-text hover:border-muted transition-colors"
        >GitHub →</a>
      </li>
    </ul>
  </div>
</nav>
